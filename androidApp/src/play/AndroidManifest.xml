<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Play flavor: enforce VoiceAppService runs in the default (main) process
         to ensure Koin/Application are initialized and avoid null/injection errors
         when Android Auto starts the car app. -->
    <application>
        <service
            android:name=".auto.VoiceAppService"
            android:process="${applicationId}">
        </service>
    </application>
</manifest>
