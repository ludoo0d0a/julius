<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Explicitly allow cleartext for local development (localhost and emulator host) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>

    <!-- Also allow cleartext for Argentina data source which has SSL certificate issues -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">datos.energia.gob.ar</domain>
    </domain-config>

    <base-config cleartextTrafficPermitted="false" />
</network-security-config>
